{
  "name": "kostolj_bele",
  "version": "2.0.1",
  "description": "A Kóstolj Bele receptes weboldal privát Windows desktop appá alakított változata.",
  "author": "Thomas Horvath",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3010",
    "dev:web": "next dev -p 3010",
    "dev:electron": "wait-on http://localhost:3010 && cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://localhost:3010 electronmon electron/main.js",
    "dev:desktop": "concurrently -k \"npm run dev:web\" \"npm run dev:electron\"",
    "build": "prisma generate && node scripts/patch-prisma-client.mjs && next build && node scripts/prepare-standalone-assets.mjs",
    "build:web": "prisma generate && node scripts/patch-prisma-client.mjs && next build && node scripts/prepare-standalone-assets.mjs",
    "build:desktop": "npm run build:web && electron-builder",
    "start": "next start",
    "start:electron": "cross-env NODE_ENV=production electron electron/main.js",
    "test:desktop": "cross-env NODE_ENV=test electron scripts/desktop-smoke-test.mjs",
    "lint": "eslint . --ext .js,.jsx,.mjs,.cjs,.ts,.tsx --ignore-pattern tmp/**",
    "postinstall": "prisma generate && node scripts/patch-prisma-client.mjs"
  },
  "build": {
    "appId": "hu.kostoljbele.desktop",
    "productName": "Kostolj Bele",
    "icon": "public/app-icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "app/**/*",
      "lib/**/*",
      "public/**/*",
      "uploads/**/*",
      "generated/**/*",
      "node_modules/.prisma/**/*",
      "utilities/**/*",
      ".next/**/*",
      "package.json",
      "next.config.mjs",
      "prisma/schema.prisma",
      "prisma/dev.db"
    ],
    "asarUnpack": [
      "generated/**/*",
      ".next/**/*",
      "prisma/**/*"
    ]
  },
  "electronmon": {
    "patterns": [
      "!prisma/dev.db",
      "!prisma/*.db",
      "!prisma/*.db-journal",
      "!prisma/*.db-wal",
      "!prisma/*.db-shm"
    ]
  },
  "dependencies": {
    "@prisma/client": "6.16.2",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.5.0",
    "electron-store": "^11.0.2",
    "next": "^15.5.0",
    "prisma": "6.16.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.3.0",
    "sass": "^1.79.4",
    "sharp": "^0.34.5",
    "wait-on": "^9.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.5.0",
    "typescript": "5.9.2"
  }
}
