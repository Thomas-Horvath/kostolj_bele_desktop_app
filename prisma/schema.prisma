
generator client {
  // A klienst külön mappába generáljuk, hogy az Electron build során
  // kiszámítható helyről tudjuk becsomagolni és importálni.
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  // A library engine nem külön query-engine folyamatot spawnol,
  // hanem a Prisma motort az app folyamatán belül tölti be.
  // Ez a telepített Windows desktop appnál stabilabb, mert így elkerüljük
  // a korábbi `spawn EPERM` hibát bejelentkezéskor és más első DB műveleteknél.
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  // A desktop authhoz ez a tabla mar jo alap:
  // - a username alapjan azonosithatunk
  // - a password mezoben hash-elt jelszo tarolhato
  // - a role mezovel egyszeruen kezelheto az admin jog
  //
  // Emiatt a next-auth kivezetesehez nem kell kulon auth schema vagy uj tabla.
  id            String   @id @default(cuid())
  name          String?
  username      String   @unique
  email         String   @unique
  emailVerified DateTime @default(now())
  password      String
  role          String   @default("USER")

  recipes  Recipe[]   @relation("UserRecipes")
  Favorite Favorite[]
}

model Recipe {
  id       Int    @id @default(autoincrement())
  name     String
  slug     String @unique
  imageURL String
  note     String?

  ingredients Ingredient[]
  steps       Step[]

  typeId Int
  type   Type @relation(fields: [typeId], references: [id], onDelete: Cascade)

  subtypeId Int?
  subtype   Subtype? @relation(fields: [subtypeId], references: [id], onDelete: SetNull)

  authorId    String
  author      User       @relation("UserRecipes", fields: [authorId], references: [id], onDelete: Cascade)
  favoritedBy Favorite[]
}

model Type {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  paramName String   @unique
  recipes   Recipe[]
  subtypes  Subtype[]
}

model Subtype {
  id        Int      @id @default(autoincrement())
  name      String
  paramName String   @unique
  typeId    Int
  type      Type     @relation(fields: [typeId], references: [id], onDelete: Cascade)
  recipes   Recipe[]

  @@unique([typeId, name])
}

model Ingredient {
  id       Int    @id @default(autoincrement())
  name     String
  amount   String
  unit     String?
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Step {
  id       Int    @id @default(autoincrement())
  content  String
  timer    Int
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Favorite {
  userId   String
  recipeId Int

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@id([userId, recipeId])
}
